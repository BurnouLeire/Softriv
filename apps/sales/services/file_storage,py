# sales/services/file_storage.py
import uuid
import logging
from django.core.files.base import ContentFile
from django.core.files.storage import default_storage

logger = logging.getLogger(__name__)


class DjangoStorageService:
    @staticmethod
    def guardar_pdf(contenido_bytes, nombre_base, carpeta='cotizaciones'):
        """
        Guarda PDF usando el storage por defecto (S3/Supabase)
        """
        try:
            # Generar nombre único
            nombre_limpio = nombre_base.replace(' ', '_').replace('/', '-')
            nombre_archivo = f"{carpeta}/{uuid.uuid4()}_{nombre_limpio}.pdf"
            
            logger.info(f"Guardando archivo: {nombre_archivo}")
            
            # Guardar usando default_storage
            ruta = default_storage.save(nombre_archivo, ContentFile(contenido_bytes))
            
            # Obtener URL pública
            url = default_storage.url(ruta)
            
            logger.info(f"Archivo guardado, URL: {url}")
            return url
            
        except Exception as e:
            logger.error(f"Error guardando PDF: {str(e)}", exc_info=True)
            raise Exception(f"Error en almacenamiento: {str(e)}")